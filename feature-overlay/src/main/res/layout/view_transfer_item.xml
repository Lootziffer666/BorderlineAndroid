<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="6dp">

    <!-- Transfer item content (tap to copy) -->
    <LinearLayout
        android:id="@+id/transferItemContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/transferItemPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:maxLines="2"
            android:textColor="#C0D0E0"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/transferItemTimestamp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:fontFamily="sans-serif"
            android:textColor="#506070"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- Pin toggle -->
    <ImageView
        android:id="@+id/transferItemPin"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/action_pin_toggle"
        android:padding="4dp"
        android:src="@drawable/ic_push_pin"
        app:tint="#607085" />

    <!-- Delete button -->
    <ImageView
        android:id="@+id/transferItemDelete"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/action_delete_item"
        android:padding="4dp"
        android:src="@drawable/ic_delete"
        app:tint="#607085" />
</LinearLayout>
