<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="288dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_overlay_panel"
    android:elevation="4dp"
    android:outlineAmbientShadowColor="#08D8C3F2"
    android:outlineSpotShadowColor="#08D8C3F2"
    android:orientation="vertical"
    android:paddingHorizontal="18dp"
    android:paddingTop="18dp"
    android:paddingBottom="12dp">

    <!-- Header: Title + Close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/snippetPanelTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.04"
            android:text="@string/panel_title_snippets"
            android:textColor="#D8DEEA"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/snippetCloseButton"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="28dp"
            android:minHeight="28dp"
            android:text="x"
            android:textColor="#6078889A"
            android:textSize="13sp"
            app:iconPadding="0dp"
            app:rippleColor="#14A8C8FF" />
    </LinearLayout>

    <!-- Search bar -->
    <EditText
        android:id="@+id/snippetSearchField"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_search_field"
        android:drawableStart="@drawable/ic_search"
        android:drawablePadding="8dp"
        android:fontFamily="sans-serif"
        android:hint="@string/snippet_search_hint"
        android:imeOptions="actionDone"
        android:importantForAutofill="no"
        android:inputType="text"
        android:maxLines="1"
        android:paddingHorizontal="12dp"
        android:textColor="#B8C8D8"
        android:textColorHint="#5068788A"
        android:textSize="12sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="10dp"
        android:alpha="0.06"
        android:background="#FFFFFF" />

    <!-- Snippet list container (scrollable) -->
    <ScrollView
        android:id="@+id/snippetScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fadingEdge="vertical"
        android:fadingEdgeLength="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/snippetListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Empty state -->
    <TextView
        android:id="@+id/snippetEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingVertical="18dp"
        android:text="@string/snippet_empty"
        android:textColor="#5068788A"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Add snippet button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/snippetAddButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="@string/snippet_add"
        android:textAllCaps="false"
        android:textColor="#90B0D0"
        android:textSize="12sp"
        app:cornerRadius="14dp"
        app:icon="@drawable/ic_add"
        app:iconSize="16dp"
        app:iconTint="#90B0D0"
        app:rippleColor="#14A8C8FF" />

    <!-- Inline edit form (initially GONE) -->
    <LinearLayout
        android:id="@+id/snippetEditContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:alpha="0.06"
            android:background="#FFFFFF" />

        <TextView
            android:id="@+id/snippetEditLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/snippet_new"
            android:textColor="#90B0D0"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/snippetEditTitle"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_search_field"
            android:fontFamily="sans-serif"
            android:hint="@string/snippet_title_hint"
            android:importantForAutofill="no"
            android:inputType="text"
            android:maxLines="1"
            android:paddingHorizontal="12dp"
            android:textColor="#B8C8D8"
            android:textColorHint="#5068788A"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/snippetEditContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_search_field"
            android:fontFamily="sans-serif"
            android:gravity="top|start"
            android:hint="@string/snippet_content_hint"
            android:importantForAutofill="no"
            android:inputType="textMultiLine"
            android:lines="3"
            android:maxLines="5"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:textColor="#B8C8D8"
            android:textColorHint="#5068788A"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/snippetEditCancel"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:minWidth="64dp"
                android:minHeight="32dp"
                android:text="@string/action_cancel"
                android:textAllCaps="false"
                android:textColor="#5068788A"
                android:textSize="12sp"
                app:cornerRadius="14dp"
                app:rippleColor="#14A8C8FF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/snippetEditSave"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:minWidth="64dp"
                android:minHeight="32dp"
                android:text="@string/action_save"
                android:textAllCaps="false"
                android:textColor="#90B0D0"
                android:textSize="12sp"
                app:cornerRadius="14dp"
                app:rippleColor="#14A8C8FF" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
