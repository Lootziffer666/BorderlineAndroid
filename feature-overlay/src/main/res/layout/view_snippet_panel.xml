<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="264dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_overlay_panel"
    android:elevation="8dp"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="14dp"
    android:paddingBottom="10dp">

    <!-- Header: Title + Close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/snippetPanelTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.02"
            android:text="@string/panel_title_snippets"
            android:textColor="#E0E6F0"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/snippetCloseButton"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="32dp"
            android:minHeight="32dp"
            android:text="✕"
            android:textColor="#80A0B0C8"
            android:textSize="14sp"
            app:iconPadding="0dp"
            app:rippleColor="#14A8C8FF" />
    </LinearLayout>

    <!-- Search bar -->
    <EditText
        android:id="@+id/snippetSearchField"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_search_field"
        android:drawableStart="@drawable/ic_search"
        android:drawablePadding="6dp"
        android:fontFamily="sans-serif"
        android:hint="@string/snippet_search_hint"
        android:imeOptions="actionDone"
        android:importantForAutofill="no"
        android:inputType="text"
        android:maxLines="1"
        android:paddingHorizontal="10dp"
        android:textColor="#C0D0E0"
        android:textColorHint="#607085"
        android:textSize="12sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:alpha="0.08"
        android:background="#FFFFFF" />

    <!-- Snippet list container (scrollable) -->
    <ScrollView
        android:id="@+id/snippetScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fadingEdge="vertical"
        android:fadingEdgeLength="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/snippetListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Empty state -->
    <TextView
        android:id="@+id/snippetEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingVertical="16dp"
        android:text="@string/snippet_empty"
        android:textColor="#607085"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Add snippet button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/snippetAddButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="@string/snippet_add"
        android:textAllCaps="false"
        android:textColor="#A8C8FF"
        android:textSize="12sp"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_add"
        app:iconSize="16dp"
        app:iconTint="#A8C8FF"
        app:rippleColor="#14A8C8FF" />

    <!-- Inline edit form (initially GONE) -->
    <LinearLayout
        android:id="@+id/snippetEditContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.08"
            android:background="#FFFFFF" />

        <TextView
            android:id="@+id/snippetEditLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/snippet_new"
            android:textColor="#A8C8FF"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/snippetEditTitle"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_search_field"
            android:fontFamily="sans-serif"
            android:hint="@string/snippet_title_hint"
            android:importantForAutofill="no"
            android:inputType="text"
            android:maxLines="1"
            android:paddingHorizontal="10dp"
            android:textColor="#C0D0E0"
            android:textColorHint="#607085"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/snippetEditContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_search_field"
            android:fontFamily="sans-serif"
            android:gravity="top|start"
            android:hint="@string/snippet_content_hint"
            android:importantForAutofill="no"
            android:inputType="textMultiLine"
            android:lines="3"
            android:maxLines="5"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp"
            android:textColor="#C0D0E0"
            android:textColorHint="#607085"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/snippetEditCancel"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:minWidth="64dp"
                android:minHeight="32dp"
                android:text="@string/action_cancel"
                android:textAllCaps="false"
                android:textColor="#607085"
                android:textSize="12sp"
                app:cornerRadius="12dp"
                app:rippleColor="#14A8C8FF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/snippetEditSave"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:minWidth="64dp"
                android:minHeight="32dp"
                android:text="@string/action_save"
                android:textAllCaps="false"
                android:textColor="#A8C8FF"
                android:textSize="12sp"
                app:cornerRadius="12dp"
                app:rippleColor="#14A8C8FF" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
