<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="264dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_overlay_panel"
    android:elevation="8dp"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="14dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/overlayTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Borderline"
            android:textColor="#E0E6F0"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.02" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/closeOverlayButton"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="✕"
            android:textColor="#80A0B0C8"
            android:textSize="14sp"
            android:minWidth="32dp"
            android:minHeight="32dp"
            app:iconPadding="0dp"
            app:rippleColor="#14A8C8FF" />
    </LinearLayout>

    <TextView
        android:id="@+id/overlayStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/status_ready"
        android:textColor="#607085"
        android:textSize="11sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.01" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:alpha="0.08"
        android:background="#FFFFFF" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/actionOneButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="4dp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="8dp"
        android:text="Action 1"
        android:textAllCaps="false"
        android:textColor="#C0D0E0"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.0"
        android:minHeight="40dp"
        app:cornerRadius="12dp"
        app:rippleColor="#14A8C8FF" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/actionTwoButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="8dp"
        android:text="Action 2"
        android:textAllCaps="false"
        android:textColor="#C0D0E0"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.0"
        android:minHeight="40dp"
        app:cornerRadius="12dp"
        app:rippleColor="#14A8C8FF" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/actionThreeButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="8dp"
        android:text="Action 3"
        android:textAllCaps="false"
        android:textColor="#C0D0E0"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.0"
        android:minHeight="40dp"
        app:cornerRadius="12dp"
        app:rippleColor="#14A8C8FF" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/actionFourButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="8dp"
        android:text="Action 4"
        android:textAllCaps="false"
        android:textColor="#C0D0E0"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.0"
        android:minHeight="40dp"
        app:cornerRadius="12dp"
        app:rippleColor="#14A8C8FF" />
</LinearLayout>
