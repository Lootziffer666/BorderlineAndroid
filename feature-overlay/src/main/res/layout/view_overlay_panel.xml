<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="288dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_overlay_panel"
    android:elevation="4dp"
    android:outlineAmbientShadowColor="#08D8C3F2"
    android:outlineSpotShadowColor="#08D8C3F2"
    android:orientation="vertical"
    android:paddingHorizontal="18dp"
    android:paddingTop="18dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/overlayTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Borderline"
            android:textColor="#D8DEEA"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.04" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/closeOverlayButton"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="x"
            android:textColor="#6078889A"
            android:textSize="13sp"
            android:minWidth="28dp"
            android:minHeight="28dp"
            app:iconPadding="0dp"
            app:rippleColor="#18A8C8FF" />
    </LinearLayout>

    <TextView
        android:id="@+id/overlayStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/status_ready"
        android:textColor="#5068788A"
        android:textSize="11sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.02" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="12dp"
        android:alpha="0.06"
        android:background="#FFFFFF" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/actionOneButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="6dp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="10dp"
        android:text="Action 1"
        android:textAllCaps="false"
        android:textColor="#B8C8D8"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.0"
        android:minHeight="40dp"
        app:cornerRadius="14dp"
        app:rippleColor="#14A8C8FF" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/actionTwoButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="10dp"
        android:text="Action 2"
        android:textAllCaps="false"
        android:textColor="#B8C8D8"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.0"
        android:minHeight="40dp"
        app:cornerRadius="14dp"
        app:rippleColor="#14A8C8FF" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/actionThreeButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="10dp"
        android:text="Action 3"
        android:textAllCaps="false"
        android:textColor="#B8C8D8"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.0"
        android:minHeight="40dp"
        app:cornerRadius="14dp"
        app:rippleColor="#14A8C8FF" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/actionFourButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="10dp"
        android:text="Action 4"
        android:textAllCaps="false"
        android:textColor="#B8C8D8"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.0"
        android:minHeight="40dp"
        app:cornerRadius="14dp"
        app:rippleColor="#14A8C8FF" />
</LinearLayout>
