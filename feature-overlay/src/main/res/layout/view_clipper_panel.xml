<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="288dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_overlay_panel"
    android:elevation="4dp"
    android:outlineAmbientShadowColor="#08D8C3F2"
    android:outlineSpotShadowColor="#08D8C3F2"
    android:orientation="vertical"
    android:paddingHorizontal="18dp"
    android:paddingTop="18dp"
    android:paddingBottom="12dp">

    <!-- Header: Title + Close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/clipperPanelTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.04"
            android:text="@string/panel_title_clipper"
            android:textColor="#D8DEEA"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clipperCloseButton"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="28dp"
            android:minHeight="28dp"
            android:text="x"
            android:textColor="#6078889A"
            android:textSize="13sp"
            app:iconPadding="0dp"
            app:rippleColor="#14A8C8FF" />
    </LinearLayout>

    <!-- Auto-grab feedback -->
    <LinearLayout
        android:id="@+id/clipperGrabStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="@string/grab_success_desc"
            android:src="@drawable/ic_check_circle"
            app:tint="#80CC80" />

        <TextView
            android:id="@+id/clipperGrabText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:text="@string/grab_success"
            android:textColor="#80CC80"
            android:textSize="11sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="10dp"
        android:alpha="0.06"
        android:background="#FFFFFF" />

    <!-- Clipboard history container (scrollable) -->
    <ScrollView
        android:id="@+id/clipperScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fadingEdge="vertical"
        android:fadingEdgeLength="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/clipperListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Empty state -->
    <TextView
        android:id="@+id/clipperEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingVertical="18dp"
        android:text="@string/clipper_empty"
        android:textColor="#5068788A"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Quick actions row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clipperCopyPackageButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:gravity="center"
            android:minHeight="32dp"
            android:text="@string/action_copy_package_short"
            android:textAllCaps="false"
            android:textColor="#5068788A"
            android:textSize="10sp"
            app:cornerRadius="14dp"
            app:rippleColor="#14A8C8FF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clipperCopyScreenButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:gravity="center"
            android:minHeight="32dp"
            android:text="@string/action_copy_screen_short"
            android:textAllCaps="false"
            android:textColor="#5068788A"
            android:textSize="10sp"
            app:cornerRadius="14dp"
            app:rippleColor="#14A8C8FF" />
    </LinearLayout>
</LinearLayout>
