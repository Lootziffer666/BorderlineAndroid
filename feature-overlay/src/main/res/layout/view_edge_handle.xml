<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/edgeHandleRoot"
    android:layout_width="34dp"
    android:layout_height="52dp"
    android:clickable="true"
    android:focusable="true"
    android:hapticFeedbackEnabled="true">

    <!-- Touch halo: invisible by default, fades in on press -->
    <View
        android:id="@+id/handleHalo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="@drawable/bg_handle_halo"
        android:visibility="invisible" />

    <!-- Accent indicator: thin vertical bar, centered -->
    <View
        android:id="@+id/handleAccent"
        android:layout_width="2dp"
        android:layout_height="16dp"
        android:layout_gravity="center"
        android:alpha="0.5"
        android:background="#A8C8FF" />

    <TextView
        android:id="@+id/handleLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:textSize="1sp" />
</FrameLayout>
